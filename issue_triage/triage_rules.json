{
  "patterns": [
    {"label": "bug", "keywords": ["crash", "exception", "not working", "fails", "error"]},
    {"label": "enhancement", "keywords": ["feature", "request", "improve", "would like", "add"]},
    {"label": "question", "keywords": ["how", "what", "documentation", "guide", "help"]}
  ],
  "priority_keywords": {
    "high": ["crash", "data loss", "cannot"],
    "medium": ["slow", "lag", "not responding", "incorrect"],
    "low": ["typo", "cosmetic", "docs"]
  },
  "default_labels": ["triage"]
}
